{
    "chat.tools.terminal.autoApprove": {
        "/^\\$extracted = Get-Content \"\\.\\\\ConsoleApp\\\\Data\\\\BoltAction\\\\USA\\.extracted\\.draft\\.json\" -Raw \\| ConvertFrom-Json\n\nfunction Parse-Costs\\(\\$profileLine\\) \\{\n    \\$costs = @\\{\\}\n    \n    # Pattern: \"75pts \\(Regular\\), 90pts \\(Veteran\\)\"\n    if \\(\\$profileLine -match '\\(\\\\d\\+\\)pts\\\\s\\*\\\\\\(Inexperienced\\\\\\)'\\) \\{ \\$costs\\['Inexperienced'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    if \\(\\$profileLine -match '\\(\\\\d\\+\\)pts\\\\s\\*\\\\\\(Regular\\\\\\)'\\) \\{ \\$costs\\['Regular'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    if \\(\\$profileLine -match '\\(\\\\d\\+\\)pts\\\\s\\*\\\\\\(Veteran\\\\\\)'\\) \\{ \\$costs\\['Veteran'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    \n    # Pattern: \"Inexperienced \\(77pts\\)\"  \n    if \\(\\$profileLine -match 'Inexperienced\\\\s\\*\\\\\\(\\(\\\\d\\+\\)pts\\\\\\)'\\) \\{ \\$costs\\['Inexperienced'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    if \\(\\$profileLine -match 'Regular\\\\s\\*\\\\\\(\\(\\\\d\\+\\)pts\\\\\\)'\\) \\{ \\$costs\\['Regular'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    if \\(\\$profileLine -match 'Veteran\\\\s\\*\\\\\\(\\(\\\\d\\+\\)pts\\\\\\)'\\) \\{ \\$costs\\['Veteran'\\] = \\[int\\]\\$matches\\[1\\] \\}\n    \n    return \\$costs\n\\}\n\nfunction Clean-Name\\(\\$name\\) \\{\n    \\$name = \\$name -replace 'S MARAUDERS', \"Merrill's Marauders\"\n    \\$name = \\$name -replace 'MM M2', '90mm M2'\n    \\$name = \\$name -replace 'MM ANTI-TANK GUN M1',' 57mm Anti-tank Gun M1'\n    \\$name = \\$name -replace 'INCH ANTI-TANK GUN M5', '3-inch Anti-tank Gun M5'\n    \\$name = \\$name -replace 'M AA GUN MK 4', 'Twin 20mm AA Gun Mk 4'\n    \\$name = \\$name -replace 'AND SHERMAN CROCODILE FLAMETHROWER TANKS', 'Sherman Crocodile'\n    \\$name = \\$name -replace 'HEAVY ASSAULT TANK', 'M4A3E2 Jumbo'\n    \\$name = \\$name -replace 'HEAVY WEAPONS RIFLE TEAM A US', 'Heavy Weapons Rifle Team'\n    \n    # Title case if all uppercase\n    if \\(\\$name -ceq \\$name\\.ToUpper\\(\\)\\) \\{\n        \\$name = \\(Get-Culture\\)\\.TextInfo\\.ToTitleCase\\(\\$name\\.ToLower\\(\\)\\)\n    \\}\n    \n    return \\$name\n\\}\n\n\\$units = @\\(\\)\nforeach \\(\\$candidate in \\$extracted\\.CandidateUnits\\) \\{\n    \\$costs = Parse-Costs \\$candidate\\.ProfileLine\n    if \\(\\$costs\\.Count -eq 0\\) \\{ continue \\}  # Skip if no costs found\n    \n    \\$experience = @\\(\\)\n    foreach \\(\\$level in @\\('Inexperienced', 'Regular', 'Veteran'\\)\\) \\{\n        if \\(\\$costs\\.ContainsKey\\(\\$level\\)\\) \\{\n            \\$experience \\+= @\\{\n                Level = \\$level\n                BaseCost = \\$costs\\[\\$level\\]\n            \\}\n        \\}\n    \\}\n    \n    \\$cleanName = Clean-Name \\$candidate\\.Name\n    \n    \\$unit = @\\{\n        Name = \\$cleanName\n        MinModels = 1\n        MaxModels = 1\n        Experience = \\$experience\n        Weapons = @\\(\\)\n    \\}\n    \n    \\$units \\+= \\$unit\n\\}\n\nWrite-Output \"Parsed \\$\\(\\$units\\.Count\\) units\"\nWrite-Output \"First 3:\"\n\\$units \\| Select-Object -First 3 \\| ConvertTo-Json -Depth 5$/": {
            "approve": true,
            "matchCommandLine": true
        },
        "Get-Culture": true,
        "Get-ModelsFromText": true,
        "Clean-UnitName": true
    }
}